# Copy this file to .env for Docker Compose and replace placeholders locally.
# The API does not load .env automatically; configure Database__Connection with
# dotnet user-secrets or export it in your shell before running the API.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_DB=weatherdb
POSTGRES_PORT=5432

# pgAdmin web UI for local database inspection.
# Replace these placeholders in src/.env; do not commit real credentials.
# Open http://localhost:${PGADMIN_PORT} after starting the pgadmin service.
PGADMIN_IMAGE=dpage/pgadmin4:latest
PGADMIN_DEFAULT_EMAIL=admin@cleanarchitecture.dev
PGADMIN_DEFAULT_PASSWORD=replace-with-local-pgadmin-password
PGADMIN_PORT=5050

# Example API connection string. Docker Compose does not need this value, but it
# is useful if you choose to export it in your shell.
Database__Connection=Host=localhost;Port=5432;Database=weatherdb;Username=postgres;Password=replace-with-local-password
